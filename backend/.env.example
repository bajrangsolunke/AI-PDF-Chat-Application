APP_ENV=development
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
JWT_EXPIRES_MIN=60
DATABASE_URL=sqlite:///./app.db
CHROMA_DIR=./chroma
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# Chat provider: "groq" (default, fast + free), "gemini", or "openai"
LLM_PROVIDER=groq
# Embed provider: "gemini" (default, free) or "openai". Groq has no embeddings.
EMBED_PROVIDER=gemini

# Groq — chat. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=replace-me
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Gemini — embeddings (and optionally chat). Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=replace-me
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# OpenAI — only needed if LLM_PROVIDER=openai or EMBED_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

CORS_ORIGINS=http://localhost:5173
